# Normalize text files to LF in the repo and working tree.
# Prevents CRLF/LF churn between Windows (autocrlf) and Prettier (which expects LF),
# which otherwise makes source files show as modified / fail format checks.
* text=auto eol=lf

# Binary assets — never normalize line endings.
*.png binary
*.PNG binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.gif binary
*.pdf binary
*.woff binary
*.woff2 binary
