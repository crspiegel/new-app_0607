<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cambridge Reading Adventures</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@600;700&family=Inter:wght@600;700;800&family=Nunito:wght@500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <button class="brand" type="button" data-view="home" aria-label="Go to main page">
          <span class="brand-name">
            <span class="brand-main">Cambridge</span>
            <span class="brand-accent">Reading Adventures</span>
          </span>
        </button>
        <nav class="top-nav" aria-label="Level navigation">
          <button class="top-nav-link nav-level-one" type="button" data-level="Level 1" aria-label="Level 1">
            <span class="nav-book" aria-hidden="true"><span class="nav-book-number">1</span></span>
            <span class="nav-book-label">Level</span>
          </button>
          <button class="top-nav-link nav-level-two" type="button" data-level="Level 2" aria-label="Level 2">
            <span class="nav-book" aria-hidden="true"><span class="nav-book-number">2</span></span>
            <span class="nav-book-label">Level</span>
          </button>
          <button class="top-nav-link nav-level-three" type="button" data-level="Level 3" aria-label="Level 3">
            <span class="nav-book" aria-hidden="true"><span class="nav-book-number">3</span></span>
            <span class="nav-book-label">Level</span>
          </button>
          <button class="top-nav-link nav-level-four" type="button" data-level="Level 4" aria-label="Level 4">
            <span class="nav-book" aria-hidden="true"><span class="nav-book-number">4</span></span>
            <span class="nav-book-label">Level</span>
          </button>
        </nav>
        <button class="status-pill" id="statusPill" type="button" data-view="overview">
          Program overview
        </button>
      </header>

      <main>
        <section class="screen screen-active" id="homeScreen" aria-labelledby="homeTitle">
          <div class="hero-section section-box section-blue">
            <div class="section-inner hero-grid">
              <div class="hero-copy">
                <span class="eyebrow">Brighter Thinking Better Learning</span>
                <h1 id="homeTitle">Cambridge Reading Adventures</h1>
                <p>
                  A colorful reading journey for young English learners, organized by
                  story bands, nonfiction topics, and classroom-friendly activities.
                </p>
                <a class="hero-cta" href="#levelTitle">Choose Your Level</a>
              </div>

              <div class="hero-stage" aria-label="Cambridge Reading Adventures characters">
                <img
                  class="hero-image"
                  src="assets/hero-builder-characters.png"
                  alt="Builder dad and child from Cambridge Reading Adventures"
                />
              </div>
            </div>
          </div>

          <section class="section-box section-white level-section" aria-labelledby="levelTitle">
            <div class="section-inner">
              <div class="section-heading">
                <span class="eyebrow blue">Start Reading</span>
                <h2 id="levelTitle">Choose Your Level</h2>
                <p>
                  Select a level to begin monthly lessons with songs, stories,
                  chants, and reading activities.
                </p>
              </div>

              <div class="level-grid" aria-label="Choose level">
                <button class="level-button level-one" type="button" data-level="Level 1">
                  <span class="level-kicker">Starter</span>
                  <strong>Level 1</strong>
                  <small>Pink A/B, Red, Yellow</small>
                </button>
                <button class="level-button level-two" type="button" data-level="Level 2">
                  <span class="level-kicker">Growing</span>
                  <strong>Level 2</strong>
                  <small>Blue, Green, Orange</small>
                </button>
                <button class="level-button level-three" type="button" data-level="Level 3">
                  <span class="level-kicker">Confident</span>
                  <strong>Level 3</strong>
                  <small>Turquoise, Purple, Gold</small>
                </button>
                <button class="level-button level-four" type="button" data-level="Level 4">
                  <span class="level-kicker">Fluent</span>
                  <strong>Level 4</strong>
                  <small>White and Adventure Strands</small>
                </button>
              </div>
            </div>
          </section>

          <section class="section-box section-white intro-section" aria-labelledby="introTitle">
            <div class="section-inner library-grid">
              <div class="library-copy">
                <span class="eyebrow green">Program Introduction</span>
                <h2 id="introTitle">A Reading Journey for Every Young Learner</h2>
                <p>
                  Cambridge Reading Adventures is a leveled reading program designed
                  to guide children from first words and simple sentence patterns to
                  richer stories, nonfiction topics, and independent reading.
                </p>
              </div>
              <figure class="library-art">
                <img src="assets/cra-books.jpg" alt="A collection of Cambridge Reading Adventures books" />
              </figure>
            </div>
          </section>

          <section class="section-box section-blue" aria-labelledby="featureTitle">
            <div class="section-inner feature-section-inner">
              <div class="section-heading">
                <span class="eyebrow">Key Features</span>
                <h2 id="featureTitle">Why Cambridge Reading Adventures Works</h2>
              </div>

              <div class="feature-grid">
                <article class="feature-card">
                  <span class="feature-icon">A</span>
                  <h3>Leveled Reading Path</h3>
                  <p>Color bands make reading progression visible and easy to guide.</p>
                </article>
                <article class="feature-card">
                  <span class="feature-icon">B</span>
                  <h3>Stories and Nonfiction</h3>
                  <p>Learners meet illustrated stories, real-world topics, animals, places, and people.</p>
                </article>
                <article class="feature-card">
                  <span class="feature-icon">C</span>
                  <h3>Classroom Ready</h3>
                  <p>Structured reading experiences support vocabulary, listening, speaking, and guided reading.</p>
                </article>
              </div>
            </div>
          </section>
        </section>

        <section class="screen" id="monthScreen" aria-labelledby="monthTitle">
          <div class="section-box section-white">
            <div class="section-inner">
              <div class="screen-heading">
                <button class="back-button" type="button" data-view="home">Back</button>
                <div>
                  <span class="eyebrow blue" id="monthLevelTag">Level</span>
                  <h2 id="monthTitle">Choose a Month</h2>
                </div>
              </div>
              <div class="month-grid" id="monthGrid" aria-label="Choose month"></div>
            </div>
          </div>
        </section>

        <section class="screen" id="overviewScreen" aria-labelledby="overviewTitle">
          <div class="section-box section-white overview-section">
            <div class="section-inner">
              <div class="screen-heading">
                <button class="back-button" type="button" data-view="home">Back</button>
                <div>
                  <span class="eyebrow blue">Program overview</span>
                  <h2 id="overviewTitle">Cambridge Reading Adventures</h2>
                </div>
              </div>

              <div class="overview-grid">
                <article class="overview-card">
                  <span class="overview-number">01</span>
                  <h3>Leveled Reading Journey</h3>
                  <p>
                    Learners move through clear reading bands, building confidence
                    from first words to richer independent reading.
                  </p>
                </article>
                <article class="overview-card">
                  <span class="overview-number">02</span>
                  <h3>Stories and Nonfiction</h3>
                  <p>
                    Illustrated fiction, real-world topics, and classroom discussion
                    prompts help children read with purpose.
                  </p>
                </article>
                <article class="overview-card">
                  <span class="overview-number">03</span>
                  <h3>Classroom Friendly Structure</h3>
                  <p>
                    Monthly lessons organize songs, chants, stories, and reading
                    activities into a predictable teaching flow.
                  </p>
                </article>
              </div>
            </div>
          </div>
        </section>

        <section class="screen" id="contentScreen" aria-labelledby="contentTitle">
          <div class="section-box section-blue">
            <div class="section-inner">
              <div class="screen-heading on-blue">
                <button class="back-button snow" type="button" data-view="months">Back</button>
                <div>
                  <span class="eyebrow snow" id="contentPathTag">March</span>
                  <h2 id="contentTitle">Level 1</h2>
                </div>
              </div>

              <div class="content-toolbar" aria-label="Lesson content types">
                <button type="button" class="content-type active">Opening Song</button>
                <button type="button" class="content-type">Story</button>
                <button type="button" class="content-type">Word Chant</button>
                <button type="button" class="content-type">Sentence Chant</button>
                <button type="button" class="content-type">Ending Song</button>
              </div>

              <div class="lesson-board" aria-label="Monthly lesson board">
                <div class="weekday-row" aria-hidden="true">
                  <span>Mon</span>
                  <span>Tue</span>
                  <span>Wed</span>
                  <span>Thu</span>
                  <span>Fri</span>
                </div>
                <div class="lesson-grid" id="lessonGrid"></div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer" aria-label="Copyright">
        <p>© Copyright 2025 TPS EDUCATION. All Rights Reserved.</p>
      </footer>
    </div>

    <script src="app.js"></script>
  </body>
</html>
